# Backtesting Agent — environment template
# Copy to .env on the server (NOT committed to git).

# -- Database --
DATABASE_URL=sqlite+aiosqlite:///data/backtest_agent.db

# -- Shared docker network the existing AI-Investment cloudflared lives on.
#    Verify on the host with:  docker network ls
#    The Compose default is `<project>_default`, lowercased. For
#    /root/AI-Investment this is usually `ai-investment_default`.
SHARED_NETWORK=ai-investment_default

# -- Public URL the dashboard will fetch from (Phase 3).
PUBLIC_API_URL=https://backtesting-agent.prismgate.net/api

# -- AI provider keys (the agent layer: analyst, auto-research loop) --
#    All providers are OpenAI-compatible. At least ONE key is needed for the
#    agent features; with none set, plain backtesting still works fully.
#    Keys are env-seeded into the ai_providers table at startup (no auth/UI
#    key management in the standalone — see EXTRACTION-PLAN.md Phase 1b).
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ZAI_API_KEY=
MOONSHOT_API_KEY=
DASHSCOPE_API_KEY=
MINIMAX_API_KEY=

# -- Optional market-data API keys (the engine falls back to Yahoo when absent) --
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=
TIINGO_API_KEY=
ALPACA_API_KEY=
ALPACA_API_SECRET=

# -- Determinism --
# When true, YahooProvider routes all fetches to the FrozenSnapshotProvider
# (parquet under data/golden/) so reruns are bit-exact. Set to false during
# initial snapshot generation. NOTE: the engine reads BACKTEST_DETERMINISM_MODE
# (not *_STRICT_*) — see determinism.py / provider.py.
BACKTEST_DETERMINISM_MODE=true
# Optional override for the snapshot path (default: data/golden/yfinance_snapshot_2026-05-21.parquet)
#BACKTEST_DATA_SNAPSHOT=
