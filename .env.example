# Backtesting Agent — environment template
# Copy to .env on the server (NOT committed to git — see .gitignore).

# ── Auth / JWT ──────────────────────────────────────────────────────────────
# Signing key for JWT access tokens. Generate a strong random value:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Encryption-at-rest for user AI-provider keys ────────────────────────────
# Fernet key used to encrypt API keys users store via the settings UI. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, keys are stored in plaintext (dev only — set this in production).
AI_KEY_ENCRYPTION_KEY=

# ── Database ────────────────────────────────────────────────────────────────
# SQLite (async). The data/ dir is a docker volume in compose (bt-backend-data).
DATABASE_URL=sqlite+aiosqlite:///data/trading.db

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API (the dashboard's public URL).
CORS_ORIGINS=https://backtesting-agent.prismgate.net

# ── AI provider keys (OPTIONAL) ─────────────────────────────────────────────
# Provider keys are normally managed PER-USER in the settings UI (encrypted at
# rest with AI_KEY_ENCRYPTION_KEY). These env vars are an optional fallback that
# seeds a shared provider at startup. Leave blank to rely on UI-managed keys.
# Reasoning-capable, mechanism-only-safe: DEEPSEEK (deepseek-reasoner).
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=

# ── Optional market-data API keys (engine falls back to Yahoo when absent) ──
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=
TIINGO_API_KEY=

# ── Determinism (optional) ──────────────────────────────────────────────────
# When true, market-data fetches route to a frozen snapshot so reruns are
# bit-exact. Leave false unless you have generated snapshots under data/golden/.
BACKTEST_DETERMINISM_MODE=false
