FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libffi-dev && \
    rm -rf /var/lib/apt/lists/*

COPY pyproject.toml ./
COPY src/ ./src/
RUN pip install --no-cache-dir -e ".[api]"

COPY tests/ ./tests/
COPY data/ ./data/

RUN mkdir -p /app/data

ENV PYTHONUNBUFFERED=1
ENV DATABASE_URL=sqlite+aiosqlite:///data/backtest_agent.db

EXPOSE 8000

# Phase 3 lands api/main.py. Until then this CMD will fail fast — that's
# intentional, so we never accidentally deploy a half-built stack.
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
